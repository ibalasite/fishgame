{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://fishing-arcade-game.contracts/BalanceDTO",
  "title": "BalanceDTO",
  "description": "玩家金幣與鑽石餘額 DTO",
  "type": "object",
  "required": ["user_id", "gold_balance", "diamond_balance"],
  "properties": {
    "user_id": {
      "type": "string",
      "description": "玩家 CUID2 ID",
      "example": "usr_01HX..."
    },
    "gold_balance": {
      "type": "integer",
      "minimum": 0,
      "description": "遊戲金幣餘額（coin，非負整數）",
      "example": 12500
    },
    "diamond_balance": {
      "type": "integer",
      "minimum": 0,
      "description": "鑽石（充值貨幣）餘額",
      "example": 80
    }
  },
  "x-source": "docs/EDD.md §10.6 BalanceDTO",
  "x-stereotype": "<<DTO>>"
}
